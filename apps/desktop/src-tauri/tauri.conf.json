{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SUPERIOR",
  "version": "0.1.0",
  "identifier": "com.superior.alpha",
  "build": {
    "beforeDevCommand": "corepack pnpm dev:vite",
    "beforeBuildCommand": "corepack pnpm build:vite",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SUPERIOR",
        "width": 1120,
        "height": 720,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/daemon/server.mjs",
      "resources/node/node.exe",
      "resources/extension"
    ]
  }
}
