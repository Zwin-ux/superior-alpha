    "start": "node dist/server.js"
  },
  "dependencies": {
    "@superior/core": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/ws": "^8.18.1",
    "tsx": "4.22.3",
    "vitest": "4.1.7"
  }
}
