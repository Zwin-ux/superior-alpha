{
  "name": "@superior/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "tsx --conditions development src/server.ts",
    "build": "tsc -p tsconfig.json",
